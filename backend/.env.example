# Database
DATABASE_URL=postgres://user:password@host:5432/pos_mashinani

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Encryption key for M-Pesa credentials at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=change-this-to-a-64-char-hex-string

# Server
PORT=3000
SERVER_URL=https://your-app.onrender.com

# M-Pesa environment (sandbox or production)
MPESA_ENV=sandbox

# Backup Object Storage (S3-compatible: Cloudflare R2, Backblaze B2, MinIO)
BACKUP_STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
BACKUP_STORAGE_REGION=auto
BACKUP_STORAGE_BUCKET=pos-backups
BACKUP_STORAGE_ACCESS_KEY=your-access-key
BACKUP_STORAGE_SECRET_KEY=your-secret-key
